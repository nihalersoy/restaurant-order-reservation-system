            "exec": [
              "pm.test('returns 400 Bad Request', function () {",
              "  pm.response.to.have.status(400);",
              "});",
              "",
              "pm.test('returns meaningful validation messages', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.status).to.eql(400);",
              "  pm.expect(json.messages).to.be.an('array').that.is.not.empty;",
              "});"
