{
  "info": {
    "_postman_id": "b5fbb0bc-57f6-4c4e-a762-restaurant-system",
    "name": "Restaurant Order and Reservation System",
    "description": "Postman tests for the Spring Boot Restaurant Order and Reservation System backend.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 Register Customer",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const runId = Date.now();",
              "const reservationDate = new Date(Date.now() + 7 * 24 * 60 * 60 * 1000);",
              "reservationDate.setHours(19, 30, 0, 0);",
              "",
              "pm.collectionVariables.set('runId', runId);",
              "pm.collectionVariables.set('customerEmail', `postman.customer.${runId}@example.com`);",
              "pm.collectionVariables.set('customerPassword', 'password123');",
              "pm.collectionVariables.set('tableNumber', Math.floor(1000 + Math.random() * 9000));",
              "pm.collectionVariables.set('reservationTime', reservationDate.toISOString().slice(0, 19));"
            ]
          }
        },
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('returns 201 Created', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('returns customer JWT', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.token).to.be.a('string').and.not.empty;",
              "  pm.expect(json.tokenType).to.eql('Bearer');",
              "  pm.expect(json.role).to.eql('CUSTOMER');",
              "  pm.collectionVariables.set('customerToken', json.token);",
              "  pm.collectionVariables.set('customerUserId', json.userId);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"fullName\": \"Postman Customer\",\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/register",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "register"
          ]
        }
      }
    },
    {
      "name": "02 Login Customer",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('returns 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('returns login JWT', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.token).to.be.a('string').and.not.empty;",
              "  pm.expect(json.email).to.eql(pm.collectionVariables.get('customerEmail'));",
              "  pm.collectionVariables.set('customerToken', json.token);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{customerEmail}}\",\n  \"password\": \"{{customerPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/login",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "auth",
            "login"
          ]
        }
      }
    },
