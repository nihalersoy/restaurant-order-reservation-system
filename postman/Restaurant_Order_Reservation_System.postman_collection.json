    {
      "name": "09 Create Reservation",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('returns 201 Created', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('returns confirmed reservation', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.reservationId).to.exist;",
              "  pm.expect(json.status).to.eql('CONFIRMED');",
              "  pm.expect(json.tableNumber).to.eql(Number(pm.collectionVariables.get('tableNumber')));",
              "  pm.collectionVariables.set('reservationId', json.reservationId);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{customerToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
