    {
      "name": "04 Get All Menu Items",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('returns 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('returns menu items and stores first item id', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.be.an('array');",
              "  pm.expect(json.length).to.be.greaterThan(0);",
              "  pm.expect(json[0]).to.have.property('id');",
              "  pm.collectionVariables.set('menuItemId', json[0].id);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/menus",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "menus"
          ]
        }
      }
    },
    {
      "name": "05 Filter Menu By Category",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('returns 200 OK', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('all returned items are MAIN_COURSE', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json).to.be.an('array');",
              "  json.forEach(item => pm.expect(item.category).to.eql('MAIN_COURSE'));",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/menus?category=MAIN_COURSE",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "menus"
          ],
          "query": [
            {
              "key": "category",
              "value": "MAIN_COURSE"
            }
          ]
        }
      }
    },
    {
      "name": "06 Create Order",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('returns 201 Created', function () {",
              "  pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test('returns order summary', function () {",
              "  const json = pm.response.json();",
              "  pm.expect(json.orderId).to.exist;",
              "  pm.expect(json.status).to.eql('PENDING');",
              "  pm.expect(json.items).to.be.an('array').with.lengthOf(1);",
              "  pm.expect(Number(json.totalAmount)).to.be.greaterThan(0);",
              "  pm.collectionVariables.set('orderId', json.orderId);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{customerToken}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"items\": [\n    {\n      \"menuItemId\": {{menuItemId}},\n      \"quantity\": 2\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/orders",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "orders"
          ]
        }
