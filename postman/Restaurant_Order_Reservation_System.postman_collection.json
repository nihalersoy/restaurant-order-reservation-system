        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tableNumber\": {{tableNumber}},\n  \"partySize\": 2,\n  \"reservationTime\": \"{{reservationTime}}\",\n  \"durationMinutes\": 90,\n  \"specialRequest\": \"Postman automated test reservation\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/reservations",
          "host": [
